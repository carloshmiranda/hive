{
  "mcpServers": {
    "hive": {
      "type": "stdio",
      "command": "node",
      "args": ["mcp/server.js"],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "CRON_SECRET": "${CRON_SECRET}",
        "NEXT_PUBLIC_URL": "${NEXT_PUBLIC_URL}",
        "GH_PAT": "${GH_PAT}"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GH_PAT}"
      }
    }
  }
}
