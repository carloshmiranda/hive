# Hive Dashboard — Environment Variables
# Copy to .env.local and fill in values

# Neon database (orchestrator state)
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-west-1.aws.neon.tech/hive?sslmode=require

# NextAuth (authentication)
AUTH_SECRET=  # Generate: openssl rand -base64 32
AUTH_GITHUB_ID=  # GitHub OAuth App → Client ID
AUTH_GITHUB_SECRET=  # GitHub OAuth App → Client Secret
ALLOWED_GITHUB_ID=  # Your GitHub user ID (numeric). Find at: api.github.com/users/carlos-miranda

# Encryption for settings storage
ENCRYPTION_KEY=  # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Public URL (for callbacks)
NEXT_PUBLIC_URL=https://hive-dashboard.vercel.app

# Stripe MCP Server (for Claude Code agent operations)
STRIPE_MCP_API_KEY=  # Restricted Stripe API key (rk_*) for MCP server access

# Note: All other API keys (Stripe, Vercel, GitHub PAT, Resend, Neon API, etc.)
# are managed through the Hive Settings page at /settings
# They're stored encrypted in Neon, not as environment variables
